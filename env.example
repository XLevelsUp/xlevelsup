# Environment Variables for XLEVELSUP

# Supabase Configuration (for ERP system)
NEXT_PUBLIC_SUPABASE_URL=https://vwgsbstkbjygokydvnia.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Google Sheets API Configuration
# Refer to secrets.json.json for actual values
# Get these from your Google Cloud Service Account JSON file

GOOGLE_SHEET_ID=

GOOGLE_CLIENT_EMAIL=

# Note: The private key should be wrapped in quotes and may contain \n for newlines
# Example: "-----BEGIN PRIVATE KEY-----\nYourKeyHere\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=""

# Optional: Admin email for notifications
ADMIN_EMAIL=

# ERP System Configuration
# JWT secret for session management - change this in production
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
