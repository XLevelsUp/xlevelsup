# Environment Variables for XLEVELSUP

# Google Sheets API Configuration
# Refer to secrets.json.json for actual values
# Get these from your Google Cloud Service Account JSON file

GOOGLE_SHEET_ID=

GOOGLE_CLIENT_EMAIL=

# Note: The private key should be wrapped in quotes and may contain \n for newlines
# Example: "-----BEGIN PRIVATE KEY-----\nYourKeyHere\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=""

# Optional: Admin email for notifications
ADMIN_EMAIL=
